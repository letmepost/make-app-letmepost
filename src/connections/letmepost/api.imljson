{
	"url": "https://api.letmepost.dev/v1/accounts",
	"method": "GET",
	"headers": {
		"Authorization": "Bearer {{parameters.apiKey}}"
	},
	"response": {
		"valid": "{{statusCode === 200}}",
		"metadata": {
			"type": "text",
			"value": "{{first(body.data).displayName}}"
		},
		"error": {
			"message": "[{{statusCode}}] {{body.error.code}}: {{body.error.message}}"
		}
	},
	"log": {
		"sanitize": ["request.headers.authorization"]
	}
}
